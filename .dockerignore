# Mirror of .gitignore, with two important differences:
#   - .git is excluded so the build context doesn't carry repo history
#   - data/cs_conversations.csv IS included (it's the input the prepare
#     stage reads); generated SQLite + Chroma artifacts are NOT

# Git
.git
.gitignore
.gitattributes

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.uv-cache/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Env / secrets — passed via env_file at run time, never baked into the image
.env
.env.local
.env.*.local

# Generated data: only the transient SQLite WAL / journal files and the
# checkpoint scratch are excluded. data/processed.db and data/chroma/ are
# committed (so reviewers can skip the preprocess step); they ride along
# in the build context but the runtime bind-mount on ./data still wins.
data/processed.db-journal
data/processed.db-wal
data/processed.db-shm
data/checkpoints/

# Eval / report artifacts
eval/results/
report/build/

# Other compose files (the langfuse one belongs to a separate stack)
docker-compose.langfuse.yml

# Editor / OS noise
.~lock.*
.vscode/
.idea/
.DS_Store
*.swp
