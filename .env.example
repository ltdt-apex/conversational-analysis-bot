# Required: Anthropic API key for Claude Sonnet 4.6 (planner/synthesizer)
# and Claude Haiku 4.5 (batch turn classification).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
ANTHROPIC_PLANNER_MODEL=claude-sonnet-4-6
ANTHROPIC_CLASSIFIER_MODEL=claude-haiku-4-5-20251001

# Paths (defaults work out of the box)
DATA_DIR=./data
SQLITE_PATH=./data/processed.db
CHROMA_PATH=./data/chroma
RAW_CSV_PATH=./data/cs_conversations.csv

# Classification batching — conservative defaults that stay under Anthropic's
# free-tier 10K output-tokens/min limit for Haiku. On higher tiers you can
# raise concurrency (e.g. 4) and batch_size (e.g. 40) for ~10x speedup.
CLASSIFY_BATCH_SIZE=20
CLASSIFY_CONCURRENCY=1

# Session memory TTL (hours)
MEMORY_TTL_HOURS=24

# Embedding model for the vector store. Default is multilingual because the
# dataset mixes English and romanized Hindi / Hinglish. Do NOT swap to an
# English-only model without first translating — see CLAUDE.md.
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Optional: Langfuse observability. Leave unset to run without tracing.
# When set, every /ask request becomes a trace in the Langfuse UI with the
# full tool-call tree, latency breakdown, input/output, and session metadata.
#
# Self-host: see README "Observability" section. After `docker compose up`
#   open http://localhost:3000, create org + project, copy keys here.
# Cloud:     sign up at https://cloud.langfuse.com → project → keys.
#
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000          # for self-host
# LANGFUSE_HOST=https://cloud.langfuse.com     # for Langfuse Cloud (default)
